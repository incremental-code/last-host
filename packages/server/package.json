  "license": "MIT",
  "keywords": [
    "last-host",
    "deploy",
    "systemd",
    "caddy",
    "sqlite"
  ],
  "scripts": {
    "test": "node --test \"src/tests/*.test.js\""
  },
  "dependencies": {
    "@incremental-code/last-host-shared": "^0.0.3"
