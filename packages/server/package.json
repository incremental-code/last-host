{
  "name": "@incremental-code/last-host-server",
  "version": "0.0.3",
  "description": "Host runtime CLI for deploying and managing last-host releases.",
  "type": "module",
  "bin": {
    "last-host-server": "bin/last-host-server.js"
  },
  "main": "./src/index.js",
