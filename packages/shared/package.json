  },
  "homepage": "https://github.com/incremental-code/last-host/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/incremental-code/last-host/issues"
  },
  "license": "MIT",
  "keywords": [
    "last-host",
    "sqlite",
    "caddy",
    "routing",
    "deploy"
  ],
  "scripts": {
    "test": "node --test \"src/tests/*.test.js\""
  }
}
