{
  "name": "@incremental-code/last-host-shared",
  "version": "0.0.3",
  "description": "Shared helpers for naming, release paths, SQLite migrations, and Caddy config in last-host.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./naming": "./src/naming.js",
    "./release-paths": "./src/release-paths.js",
    "./sqlite": "./src/sqlite.js",
    "./caddy": "./src/caddy.js"
  },
  "files": [
    "src/*.js",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
