{
  "name": "last-host-root",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "last-host-root",
      "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/cli"
      ]
    },
    "node_modules/@incremental-code/last-host-cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@incremental-code/last-host-server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/@incremental-code/last-host-shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/cli": {
      "name": "@incremental-code/last-host-cli",
      "version": "0.0.4",
      "license": "MIT",
      "dependencies": {
        "@incremental-code/last-host-shared": "^0.0.3"
      },
      "bin": {
        "last-host": "bin/last-host.js"
      }
    },
    "packages/server": {
      "name": "@incremental-code/last-host-server",
      "version": "0.0.3",
      "license": "MIT",
      "dependencies": {
        "@incremental-code/last-host-shared": "^0.0.3"
      },
      "bin": {
        "last-host-server": "bin/last-host-server.js"
      }
    },
    "packages/shared": {
      "name": "@incremental-code/last-host-shared",
      "version": "0.0.3",
      "license": "MIT"
    }
  }
}
